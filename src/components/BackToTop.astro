<button
  data-testId="back-to-top-button"
  type="button"
  aria-label="back to top button"
  data-mdb-ripple="true"
  data-mdb-ripple-color="light"
  class="fixed bottom-5 right-5 z-50 hidden flex-col items-center rounded border border-terminal-green bg-base-200 px-3 py-2 font-mono text-xs text-terminal-green shadow-terminal transition-all duration-200 hover:bg-terminal-green hover:text-terminal-gray-900"
  id="btn-back-to-top"
>
  <span class="text-lg leading-none">^</span>
  <span class="text-[10px]">TOP</span>
</button>

<script>
  let mybutton = document.getElementById(
    'btn-back-to-top'
  ) as HTMLButtonElement;
  window.onscroll = function (event) {
    event.preventDefault();
    scrollFunction();
  };

  function scrollFunction() {
    if (
      document.body.scrollTop > 20 ||
      document.documentElement.scrollTop > 20
    ) {
      mybutton.style.display = 'flex';
    } else {
      mybutton.style.display = 'none';
    }
  }

  mybutton.addEventListener('click', backToTop);

  function backToTop(event) {
    event.preventDefault();
    document.body.scrollTop = 0;
    document.documentElement.scrollTop = 0;
  }
</script>
