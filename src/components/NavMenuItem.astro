---
interface Props {
  href: string;
  currentPath: string;
}

const { href, currentPath } = Astro.props;
const active = currentPath === href;

// Convert display name to command-style format
const displayText = await Astro.slots.render('default');
const commandName = displayText.toLowerCase().replace(/\s+/g, '-');
---

<a
  href={href}
  class:list={[
    'inline-flex items-center font-mono text-sm transition-colors duration-200',
    active
      ? 'text-terminal-green'
      : 'text-terminal-gray-400 hover:text-terminal-green',
  ]}
>
  <span class:list={['mr-1', active ? 'text-terminal-green' : 'text-terminal-gray-500']}>
    {'> '}
  </span>
  <span>./</span>
  <span class:list={[active && 'glow-green']}>{commandName}</span>
</a>
