---
import '@styles/custom.css';

import Footer from '@partials/Footer.astro';
import Navbar from '@partials/Navbar.astro';
import { AppConfig } from '@utils/AppConfig';
import { personSchemaMarkup, websiteSchemaMarkup, generateBreadcrumbSchema, generateArticleSchema } from '@utils/schemaMarkup';

export interface Props {
  head: {
    title: string;
    description: string;
    ogImage?: string;
    ogType?: string;
    url?: string;
    breadcrumbs?: { name: string; url: string }[];
    articleSchema?: {
      title: string;
      description: string;
      url: string;
      imageUrl: string;
      datePublished: string;
      dateModified?: string;
    };
  };
}

const {
  head: { title, description, ogImage, ogType, url, breadcrumbs, articleSchema },
} = Astro.props as Props;

const breadcrumbSchema = breadcrumbs ? generateBreadcrumbSchema(breadcrumbs) : null;
const articleJsonLd = articleSchema ? generateArticleSchema(articleSchema) : null;
---

<html lang="en" data-theme="terminal-dark">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="msvalidate.01" content="A3AA1AEE6C57EE63539E74E67696D204" />
    <meta name="yandex-verification" content="80c2ec5bdd10aed3" />
    <meta name="robots" content="index, follow, max-image-preview:large, max-snippet:-1, max-video-preview:-1" />
    <meta property="og:type" content={ogType || 'website'} />
    <meta property="og:locale" content="en_US" />
    <meta property="og:site_name" content={AppConfig.site_name} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={url || AppConfig.site_url} />
    <meta property="og:image" content={`${ogImage}`} />
    <meta property="og:image:alt" content={AppConfig.title} />

    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:widgets:new-embed-design" content="on" />
    <meta name="twitter:site" content={AppConfig.twitter_handle} />
    <meta name="twitter:url" content={url || AppConfig.site_url} />
    <meta name="twitter:creator" content={AppConfig.twitter_handle} />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />
    <meta name="twitter:image:alt" content={AppConfig.title} />

    <title>{title}</title>
    <meta name="description" content={description} />
    <meta name="author" content={AppConfig.author} />
    <meta name="keywords" content={AppConfig.keywords} />
    <link rel="alternate" type="application/rss+xml" href="/rss.xml" title="Akhil G Krishnan Blog RSS Feed" />
    <link rel="canonical" href={url || AppConfig.site_url} />
    <link rel="sitemap" href="/sitemap-index.xml" />
    <link rel="icon" type="image/svg+xml" href="/assets/images/favicon.svg" />
    <link rel="apple-touch-icon" href="/assets/images/favicon.svg" />
    <link rel="manifest" href="/manifest.webmanifest" />
    <meta name="theme-color" content="#22c55e" />

    <!-- JetBrains Mono Font Preload -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link rel="preload" as="style" href="https://fonts.googleapis.com/css2?family=JetBrains+Mono:wght@300;400;500;600;700&display=swap" />

    <link rel="preconnect" href="https://cdn.jsdelivr.net" />
    <link rel="dns-prefetch" href="https://cdn.jsdelivr.net" />
    <link
      rel="stylesheet"
      href="https://cdn.jsdelivr.net/gh/devicons/devicon@v2.15.1/devicon.min.css"
    />

    <script
      is:inline
      type="application/ld+json"
      set:html={JSON.stringify(websiteSchemaMarkup)}
    />

    <script
      is:inline
      type="application/ld+json"
      set:html={JSON.stringify(personSchemaMarkup)}
    />

    {breadcrumbSchema && (
      <script
        is:inline
        type="application/ld+json"
        set:html={JSON.stringify(breadcrumbSchema)}
      />
    )}

    {articleJsonLd && (
      <script
        is:inline
        type="application/ld+json"
        set:html={JSON.stringify(articleJsonLd)}
      />
    )}

    <!-- Theme initialization (runs before page renders to prevent flash) -->
    <script is:inline>
      (function() {
        const savedTheme = sessionStorage.getItem('data-theme') || 'terminal-dark';
        document.documentElement.setAttribute('data-theme', savedTheme);
      })();
    </script>

    <!-- Google tag (gtag.js) -->
    <script
      is:inline
      async
      src="https://www.googletagmanager.com/gtag/js?id=G-NXPS1JLJ55"
    />
    <script is:inline>
      window.dataLayer = window.dataLayer || [];
      function gtag() {
        dataLayer.push(arguments);
      }
      gtag('js', new Date());
      gtag('config', 'G-NXPS1JLJ55');
    </script>
  </head>
  <body class="bg-base-100 font-mono text-base-content">
    <Navbar path={Astro.url.pathname} />

    <slot />

    <Footer />

    <!-- Theme toggle script -->
    <script is:inline>
      function updateAllToggleIcons(theme) {
        var sunIcons = document.querySelectorAll('[data-sun-icon]');
        var moonIcons = document.querySelectorAll('[data-moon-icon]');

        sunIcons.forEach(function(icon) {
          if (theme === 'terminal-dark') {
            icon.classList.remove('hidden');
          } else {
            icon.classList.add('hidden');
          }
        });

        moonIcons.forEach(function(icon) {
          if (theme === 'terminal-dark') {
            icon.classList.add('hidden');
          } else {
            icon.classList.remove('hidden');
          }
        });
      }

      // Set initial icons
      var currentTheme = document.documentElement.getAttribute('data-theme') || 'terminal-dark';
      updateAllToggleIcons(currentTheme);

      // Add click handlers to all theme toggle buttons
      var toggleButtons = document.querySelectorAll('[data-theme-toggle]');
      toggleButtons.forEach(function(btn) {
        btn.addEventListener('click', function() {
          var current = document.documentElement.getAttribute('data-theme');
          var newTheme = current === 'terminal-dark' ? 'terminal-light' : 'terminal-dark';

          document.documentElement.setAttribute('data-theme', newTheme);
          sessionStorage.setItem('data-theme', newTheme);
          updateAllToggleIcons(newTheme);
        });
      });
    </script>
  </body>
</html>
